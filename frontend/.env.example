# Cloudflare Pages frontend only
# In Cloudflare: Pages project → Settings → Environment variables → Production

# ── Split deploy (required on Cloudflare Pages) ───────────────────────────────

# Full URL of the Railway backend (no trailing slash).
# The browser calls this URL for /auth, /chat, /leads, etc.
#
# Example after deploy:
# VITE_API_BASE_URL=https://stratos-hub-production.up.railway.app
VITE_API_BASE_URL=

# ── Local development ─────────────────────────────────────────────────────────

# Option A — easiest (recommended): leave VITE_API_BASE_URL empty.
# Vite proxies API routes to http://localhost:3001 automatically.
#
# Option B — test split deploy locally (same as production):
# VITE_API_BASE_URL=http://localhost:3001
# Also set backend ALLOWED_ORIGINS=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
