# Railway backend only — copy to backend/.env for local dev
# In Railway: Project → your API service → Variables

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL (Railway Postgres plugin injects this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth + encryption (generate with: openssl rand -hex 64)
JWT_SECRET=your-very-long-random-secret-here

# Admin / BYOK encryption (generate with: openssl rand -hex 32)
MASTER_SECRET=your-master-secret-here

# ── AI ────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

# ── Split deploy (frontend on Cloudflare Pages) ───────────────────────────────

# Comma-separated list of frontend origins allowed to call this API.
# Must include your Cloudflare Pages URL (no trailing slash).
#
# Example after deploy:
# ALLOWED_ORIGINS=https://stratos-hub.pages.dev,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── Optional ──────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
PORT=3001
NODE_ENV=production
